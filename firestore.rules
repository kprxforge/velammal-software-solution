rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBAL HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() && incoming().buyerId == request.auth.uid;
      allow read, list: if isSignedIn() && (isAdmin() || resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // APPLICATIONS
    // ---------------------------------------------------------
    
    // Helper to validate common application fields
    function isValidApplication(data) {
      return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 20 &&
             data.college is string && data.college.size() > 0 && data.college.size() <= 200 &&
             data.createdAt == request.time;
    }

    match /internship_applications/{applicationId} {
      allow create: if isSignedIn() && isValidId(applicationId) && isValidApplication(incoming()) &&
                    incoming().status == 'Pending Review';
      allow read, list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['paymentScreenshotUrl', 'paymentStatus']) &&
        incoming().paymentStatus == 'pending'
      );
      allow delete: if isAdmin();
    }

    match /project_applications/{applicationId} {
      allow create: if isSignedIn() && isValidId(applicationId) && isValidApplication(incoming()) &&
                    incoming().description is string && incoming().description.size() > 0 &&
                    incoming().status == 'Pending Review';
      allow read, list: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['paymentScreenshotUrl', 'paymentStatus']) &&
        incoming().paymentStatus == 'pending'
      );
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // CATALOG & CONFIG
    // ---------------------------------------------------------
    
    match /internships/{internshipId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read, list: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().active == false;
      allow update, delete: if isAdmin();
    }

    match /config/payment {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // ADMINS
    // ---------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.token.email == 'sit24am005@sairamtap.edu.in' || isAdmin());
    }
  }
}
